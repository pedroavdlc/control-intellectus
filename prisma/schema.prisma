generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Device {
  id        String     @id @default(uuid())
  phone     String     @unique
  provider  String?
  locations Location[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Location {
  id            String   @id @default(uuid())
  deviceId      String
  device        Device   @relation(fields: [deviceId], references: [id])
  lat           Float
  lng           Float
  antennaLat    Float?
  antennaLng    Float?
  radius        Float?
  address       String?
  date          String?
  timestamp     BigInt?
  antennaSector String?  // Stringified JSON
  fileId        String?  // Relation to FileRecord
  file          FileRecord? @relation(fields: [fileId], references: [id])
  createdAt     DateTime @default(now())
}

model FileRecord {
  id        String     @id @default(uuid())
  fileName  String
  filePath  String
  fileType  String     // 'PDF' or 'Excel'
  phone     String?
  date      DateTime?
  locations Location[]
  createdAt DateTime   @default(now())
}

model Consultation {
  id             String   @id @default(uuid())
  numProg        Int?     @unique
  folio          String?
  phone          String
  date           String?  // Fecha técnica de la búsqueda / del archivo
  author         String?  // Quién la pidió
  company        String?  // AT&T, Telcel, etc.
  type           String   // 'GEO' o 'SABANA'
  area           String?
  result         String?  // 'POSITIVO', 'NEGATIVO', 'PENDIENTE'
  creditsUsed    Int      @default(1)
  filePath       String?
  createdAt      DateTime @default(now())
}
