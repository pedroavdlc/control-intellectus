generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Device {
  id        String     @id @default(uuid())
  phone     String     @unique
  locations Location[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Location {
  id            String   @id @default(uuid())
  deviceId      String
  device        Device   @relation(fields: [deviceId], references: [id])
  lat           Float
  lng           Float
  antennaLat    Float?
  antennaLng    Float?
  radius        Float?
  address       String?
  date          String?
  timestamp     BigInt?
  antennaSector String?  // Stringified JSON
  createdAt     DateTime @default(now())
}
